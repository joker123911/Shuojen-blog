{
  "name": "my-blog",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
	"check": "node scripts/check-broken-links.js",
    "prestart": "git pull",
    "prepare-data": "node scripts/sync-build-time.js && node scripts/update-stats.js && node scripts/gen-photos.js && node scripts/generate-calendar.js",
    "start": "npm run prepare-data && docusaurus start",
    "build": "npm run prepare-data && docusaurus build",
    "deploy": "npm run prepare-data && docusaurus deploy",
    "push": "npm run prepare-data && node scripts/push.js",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@chess-barebones/chess": "^0.1.0",
    "@chess-barebones/chess-react": "^0.1.0",
    "@chess-barebones/core": "^0.1.0",
    "@docusaurus/core": "^3.9.1",
    "@docusaurus/preset-classic": "^3.9.1",
    "@easyops-cn/docusaurus-search-local": "^0.52.1",
    "@mdx-js/react": "^3.0.0",
    "chess.js": "^1.4.0",
    "clsx": "^2.0.0",
    "cm-chessboard": "^8.11.0",
    "lucide-react": "^0.562.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-chessboard": "^5.8.6",
    "react-dom": "^19.0.0",
    "react-fast-marquee": "^1.6.5",
    "react-photo-album": "^3.4.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.1",
    "@docusaurus/types": "^3.9.1",
    "gray-matter": "^4.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}